{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/graph.js": {
      "maxDuration": 10,
      "includeFiles": "public/artifacts/**/*.json"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; font-src 'self'; frame-ancestors 'none'" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.+).css",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).json",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).woff2",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).woff",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).jpeg",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).gif",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).ico",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    },
    {
      "source": "/(.+).wasm",
      "headers": [
        { "key": "Cache-Control", "value": "public, immutable" }
      ]
    }
  ]
}
